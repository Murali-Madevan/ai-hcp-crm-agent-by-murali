# Groq LLM
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=gemma2-9b-it
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Database - use Postgres or MySQL in production, SQLite works out of the box for local dev/demo
# Postgres example: postgresql+psycopg2://user:password@localhost:5432/hcp_crm
# MySQL example:    mysql+pymysql://user:password@localhost:3306/hcp_crm
DATABASE_URL=sqlite:///./hcp_crm.db

# CORS
FRONTEND_ORIGIN=http://localhost:5173
